# ---------------------------------------------------------------------------
# GTAI — Git LFS trackers
#
# Unreal Engine binary assets are large and churn poorly in plain Git. Track
# them with Git LFS so the repository stays cloneable. Run `git lfs install`
# once on a fresh clone, then `git lfs pull` to fetch the actual objects.
#
# Tracked per the GTAI build spec: .uasset, .umap, .fbx, .png, .wav, .mp3
# plus common UE5 companion formats for each.
# ---------------------------------------------------------------------------

# Unreal asset / level binaries
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap   filter=lfs diff=lfs merge=lfs -text

# 3D / mesh source assets
*.fbx    filter=lfs diff=lfs merge=lfs -text
*.obj    filter=lfs diff=lfs merge=lfs -text
*.gltf   filter=lfs diff=lfs merge=lfs -text
*.glb    filter=lfs diff=lfs merge=lfs -text

# Textures
*.png    filter=lfs diff=lfs merge=lfs -text
*.jpg    filter=lfs diff=lfs merge=lfs -text
*.jpeg   filter=lfs diff=lfs merge=lfs -text
*.tga    filter=lfs diff=lfs merge=lfs -text
*.exr    filter=lfs diff=lfs merge=lfs -text
*.hdr    filter=lfs diff=lfs merge=lfs -text
*.dds    filter=lfs diff=lfs merge=lfs -text
*.tiff   filter=lfs diff=lfs merge=lfs -text
*.webp   filter=lfs diff=lfs merge=lfs -text

# Audio
*.wav    filter=lfs diff=lfs merge=lfs -text
*.mp3    filter=lfs diff=lfs merge=lfs -text
*.ogg    filter=lfs diff=lfs merge=lfs -text

# Never let LFS touch source / build scripts
*.cs    -text
*.cpp   -text
*.h     -text
*.uproject -text
*.uplugin   -text
